# Django Core Settings
# IMPORTANT: Never commit .env file to version control
# Copy this file to .env and fill in your actual values

# Security
SECRET_KEY=your-secret-key-here-change-in-production
# DEBUG defaults to False. Set to True only for local development.
DEBUG=True

# Allowed hosts (comma-separated for multiple hosts)
ALLOWED_HOSTS=localhost,127.0.0.1

# HTTPS hardening — uncomment and set once your domain has a valid TLS certificate
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True

# Database Configuration (optional - defaults to SQLite)
# DATABASE_ENGINE=django.db.backends.postgresql
# DATABASE_NAME=auction_db
# DATABASE_USER=postgres
# DATABASE_PASSWORD=your-password
# DATABASE_HOST=localhost
# DATABASE_PORT=5432

# Email Configuration (optional - defaults to console backend)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# Site admin — receives seller notifications and auction-closed summaries
ADMIN_EMAIL=admin@yourdomain.com

# Cloudflare R2 Media Storage (optional - defaults to local media/)
# CF_R2_ACCOUNT_ID=your-account-id
# CF_R2_ACCESS_KEY_ID=your-access-key-id
# CF_R2_SECRET_ACCESS_KEY=your-secret-access-key
# CF_R2_BUCKET_NAME=asq-media
# CF_R2_CUSTOM_DOMAIN=media.yourdomain.com  # optional public domain for bucket

# Social Auth — Google (console.cloud.google.com)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Social Auth — Facebook (developers.facebook.com)
# FACEBOOK_APP_ID=your-facebook-app-id
# FACEBOOK_APP_SECRET=your-facebook-app-secret

# Social Auth — Microsoft (portal.azure.com)
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
